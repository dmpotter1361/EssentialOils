<?xml version="1.0" encoding="utf-8"?>
<!--
  Essential Oil Mixer installer (WiX v4+ syntax).
  - MajorUpgrade auto-removes any older version on install (no manual uninstall first).
  - UpgradeCode must stay constant forever; bump Version each release to trigger upgrades.
  - Version comes from build.ps1 (-d Version=...); the default below is just a fallback.
  - Files harvests the entire self-contained publish folder.
-->
<?ifndef Version ?><?define Version = "1.0.0" ?><?endif?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Essential Oil Mixer"
           Manufacturer="Michael Potter"
           Version="$(var.Version)"
           UpgradeCode="5C514E50-E8A1-4E70-9EFB-E76B41E2D3BC"
           Scope="perMachine"
           Compressed="yes">

    <!-- Replace any older install automatically; block downgrades with a friendly message. -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of Essential Oil Mixer is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\Resources\Icon1.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPNOREPAIR" Value="1" />
    <Property Id="ARPHELPLINK" Value="https://github.com/dmpotter1361/EssentialOils" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Essential Oil Mixer" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <Feature Id="Main" Title="Essential Oil Mixer" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentRef Id="AppShortcut" />
    </Feature>

    <!-- All published files (self-contained app + .NET runtime). -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <!-- Start-Menu shortcut. -->
    <Component Id="AppShortcut" Directory="ProgramMenuFolder" Guid="*">
      <Shortcut Id="StartMenuShortcut"
                Name="Essential Oil Mixer"
                Description="Blend essential oils into a dilution recipe"
                Target="[INSTALLFOLDER]EssentialOils.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="AppIcon" />
      <RegistryValue Root="HKCU" Key="Software\EssentialOils" Name="installed" Type="integer" Value="1" KeyPath="yes" />
    </Component>

  </Package>
</Wix>
